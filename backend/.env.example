PORT=3000

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=
DATABASE_NAME=maison_sent

JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=30d

# Firebase (leave blank to disable push notifications)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Redis / BullMQ — required; app exits loudly if REDIS_HOST is missing or unreachable
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
QUEUE_PREFIX=maison-sent

# Scheduled jobs
APP_TIMEZONE=Africa/Harare
JOB_LOW_STOCK_DIGEST_HOUR=8
JOB_STALE_TRANSFER_HOURS=48
