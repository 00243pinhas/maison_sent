# Copy this file to .env and fill in your values before running docker-compose

# PostgreSQL — used by both the postgres container and the backend
POSTGRES_USER=maison
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=maison_sent

# JWT — generate two different long random strings (openssl rand -hex 64)
JWT_ACCESS_SECRET=change_me_very_long_random_string
JWT_REFRESH_SECRET=change_me_different_very_long_random_string
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=30d

# App
PORT=3000
QUEUE_PREFIX=maison-sent
APP_TIMEZONE=Africa/Harare
JOB_LOW_STOCK_DIGEST_HOUR=8
JOB_STALE_TRANSFER_HOURS=48

# CORS — set to your Vercel frontend URL once deployed
CORS_ORIGIN=https://your-app.vercel.app

# Firebase (leave blank to disable push notifications)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
